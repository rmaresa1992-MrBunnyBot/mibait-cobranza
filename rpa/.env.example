# Conexion a SQL Server (instancia local, memoria compartida, sin puerto)
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=localhost\SQLEXPRESS
DB_DATABASE=MiBait_Cobranza
DB_UID=usuario_sql
DB_PWD=contraseña_sql
# Prefijo de tablas. Vacio = base local con nombres simples (dbo).
# Para la base real via linked server (4 partes), p. ej.:
# DB_PREFIX=[10.80.11.72\INTELIX].[Despliegue_Bait_Cobranza].[dbo]
DB_PREFIX=

# RPA
MIBAIT_URL=https://mibait.com/
# Sobrescribe la configuracion de la BD si se define (opcional)
# RPA_HEADLESS=false
